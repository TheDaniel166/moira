+def _topocentric_solar_geometry_batch(
+    calc: EclipseCalculator,
+    jd_ut: float,
+    lats,
+    lons,
+):
+    """
+    Compute Sun-Moon topocentric angular separations for N observer locations.
+
+    Calls sky_position_at once for each body without observer coordinates so
+    the topocentric correction is skipped, giving the geocentric apparent
+    position. Reconstructs True Equatorial xyz from RA/Dec/distance, then
+    fans the topocentric correction over all N candidates in one numpy pass.
+
+    Parameters
+    ----------
+    calc : EclipseCalculator
+    jd_ut : float
+    lats : array-like (N,)  geodetic latitudes, degrees
+    lons : array-like (N,)  east longitudes, degrees
+
+    Returns
+    -------
+    ndarray (N,)  Sun-Moon angular separations in degrees;
+                  np.inf where Sun altitude <= 0.
+    """
+    lats = _np.asarray(lats, dtype=_np.float64)
+    lons = _np.asarray(lons, dtype=_np.float64)
+
+    # Geocentric apparent positions in True Equatorial cartesian (km).
+    # planet_at with frame='cartesian' and no observer_lat/lon skips the
+    # topocentric correction step, giving the pure geocentric apparent vector.
+    sun_cart  = planet_at(Body.SUN,  jd_ut, reader=calc._reader, frame='cartesian')
+    moon_cart = planet_at(Body.MOON, jd_ut, reader=calc._reader, frame='cartesian')
+
+    sun_xyz  = _np.array([sun_cart.x,  sun_cart.y,  sun_cart.z],  dtype=_np.float64)
+    moon_xyz = _np.array([moon_cart.x, moon_cart.y, moon_cart.z], dtype=_np.float64)
+
+    # Greenwich Apparent Sidereal Time (longitude 0 gives GAST)
+    gast_deg = local_sidereal_time(jd_ut, 0.0)
+
+    # Batch topocentric correction — (N, 3) topocentric True Equatorial positions
+    sun_topo  = topocentric_correction_batch_np(sun_xyz,  lats, lons, gast_deg)
+    moon_topo = topocentric_correction_batch_np(moon_xyz, lats, lons, gast_deg)
+
+    # Convert topocentric xyz to RA/Dec
+    sun_r  = _np.linalg.norm(sun_topo,  axis=1)   # (N,)
+    moon_r = _np.linalg.norm(moon_topo, axis=1)   # (N,)
+
+    sun_dec  = _np.arcsin(_np.clip(sun_topo[:,  2] / sun_r,  -1.0, 1.0))
+    sun_ra   = _np.arctan2(sun_topo[:, 1],  sun_topo[:, 0])
+    moon_dec = _np.arcsin(_np.clip(moon_topo[:, 2] / moon_r, -1.0, 1.0))
+    moon_ra  = _np.arctan2(moon_topo[:, 1], moon_topo[:, 0])
+
+    # Sun altitude — needed to filter observers where Sun is below horizon.
+    # The scalar _topocentric_solar_geometry uses sky_position_at which applies
+    # atmospheric refraction (~0.575° at the horizon), so we add the same margin
+    # here: sun_above when geometric altitude > -0.575° (sin > -0.01003).
+    _SIN_REFRACTION_MARGIN = -0.01003  # sin(-0.575°)
+    lats_r = _np.radians(lats)
+    last_r = _np.radians(gast_deg + lons)   # Local Apparent Sidereal Time
+    ha_sun = last_r - sun_ra                 # hour angle
+    sin_alt = (
+        _np.sin(lats_r) * _np.sin(sun_dec)
+        + _np.cos(lats_r) * _np.cos(sun_dec) * _np.cos(ha_sun)
+    )
+    sun_above = sin_alt > _SIN_REFRACTION_MARGIN
+
+    # Vectorised spherical angular separation (law of cosines)
+    cos_sep = (
+        _np.sin(sun_dec) * _np.sin(moon_dec)
+        + _np.cos(sun_dec) * _np.cos(moon_dec) * _np.cos(sun_ra - moon_ra)
+    )
+    sep_deg = _np.degrees(_np.arccos(_np.clip(cos_sep, -1.0, 1.0)))
+
+    sep_deg[~sun_above] = _np.inf
